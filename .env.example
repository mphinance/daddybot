# --- Discord (required to connect) ---
# Bot token from https://discord.com/developers/applications → Bot
DISCORD_BOT_TOKEN=
# Application (client) ID from the same app's General Information page
DISCORD_CLIENT_ID=
# Optional: a dev guild id. Set it to register slash commands instantly there
# (global registration can take up to an hour to propagate). Leave blank for global.
DISCORD_GUILD_ID=

# --- TraderDaddy Pro data ---
# Your own td_live_ key. LEAVE BLANK to run in keyless demo mode (typed fixtures).
# The key stays on this host and only talks to api.traderdaddy.pro.
TD_API_KEY=

# --- Scheduled alerts (optional) ---
# Channel id to post unusual-activity alerts into. Blank = alerts disabled.
ALERT_CHANNEL_ID=
# Poll interval in ms (default 60000).
ALERT_INTERVAL=60000
# Minimum single-print premium to consider (default 250000).
ALERT_MIN_PREMIUM=250000
# Comma-separated tiers to post (default ELITE,LEGENDARY).
ALERT_MIN_TIERS=ELITE,LEGENDARY
